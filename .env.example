# =====================================================================
# Modèle de configuration — CMSFP Platform
# =====================================================================
# Copier ce fichier vers `.env` et adapter les valeurs pour votre
# environnement.
#
#     cp .env.example .env
#
# ⚠️  En production, NE JAMAIS utiliser les valeurs ci-dessous.
#     Toutes les valeurs marquées [CHANGEZ-MOI] DOIVENT être remplacées.
# =====================================================================

# --- Application ---
APP_NAME=CMSFP Platform
VERSION=1.1.0
# dev | staging | production
ENVIRONMENT=production

# --- Base de données ---
DATABASE_URL=sqlite+aiosqlite:///./cmsfp.db
# Mettre à false en production (utiliser des migrations Alembic)
AUTO_CREATE_TABLES=false

# --- Sécurité / JWT (A02 — pas de valeur par défaut en dur) ---
# Générer un secret fort :
#   python3 -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=[CHANGEZ-MOI-générer-avec-secrets-token-urlsafe-64]
ALGORITHM=HS256

# --- Durée des tokens (A07 — réduit de 8h à 1h + refresh) ---
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Bootstrap admin (A07 — credentials via env, jamais en dur) ---
# Premier compte administrateur. Au démarrage, l'app crée cet utilisateur
# s'il n'existe pas déjà.
CMSFP_BOOTSTRAP_ADMIN_USERNAME=[CHANGEZ-MOI-nom-utilisateur-admin]
CMSFP_BOOTSTRAP_ADMIN_PASSWORD=[CHANGEZ-MOI-mot-de-passe-fort-≥16-caractères]
CMSFP_BOOTSTRAP_ADMIN_ROLE=admin

# --- CORS (A05) ---
# Origines autorisées, séparées par des virgules.
# En production : lister uniquement les domaines du frontend.
CORS_ORIGINS=https://cmsfp.example.gov

# --- Rate limiting (A01 — protection brute-force sur /login) ---
LOGIN_RATE_LIMIT=5/minute

# --- Upload audio (A10 — taille max en octets, défaut 50 Mo) ---
AUDIO_MAX_UPLOAD_BYTES=52428800
